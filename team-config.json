{
  "$schema": "./config-schema.json",
  "version": "4.0.0",
  "ai": {
    "defaultProvider": "gemini",
    "providers": {
      "gemini": {
        "models": [
          { "name": "gemini-flash-lite-latest", "enabled": 1 },
          { "name": "gemini-flash-latest", "enabled": 1 },
          { "name": "gemini-pro-latest", "enabled": 0 },
          { "name": "gemini-3.5-flash", "enabled": 1 },
          { "name": "gemini-3.1-flash-lite", "enabled": 1 },
          { "name": "gemini-2.5-flash", "enabled": 1 },
          { "name": "gemini-2.5-flash-lite", "enabled": 1 }
        ]
      },
      "openai": {
        "models": [
          { "name": "gpt-5.4", "enabled": 1 },
          { "name": "o4-mini", "enabled": 0 }
        ]
      },
      "claude": {
        "models": [
          { "name": "claude-sonnet-5", "enabled": 1 },
          { "name": "claude-fable-5", "enabled": 0 }
        ]
      },
      "ollama": {
        "models": [
          { "name": "gemma4:e2b", "enabled": 1 },
          { "name": "gemma4:e4b", "enabled": 1 },
          { "name": "qwen3.5-chat:9b", "enabled": 1 },
          { "name": "gpt-oss:20b", "enabled": 1 }
        ]
      }
    },
    "requestConfig": {
      "maxRetries": 3,
      "timeout": 120000,
      "baseDelay": 10000,
      "maxDelay": 30000
    }
  },
  "git": {
    "conventionalCommits": {
      "defaultLanguage": "en",
      "includeBody": true,
      "includeFooter": false
    }
  },
  "docs": {
    "language": "zh-TW"
  },
  "testing": {
    "framework": "vitest",
    "coverageThresholds": {
      "branches": 85,
      "functions": 90,
      "lines": 85,
      "statements": 85
    }
  },
  "typescript": {
    "enabled": true,
    "version": "5.5.3",
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "codeQuality": {
    "eslint": {
      "enabled": true,
      "strictMode": true,
      "plugins": ["typescript-eslint", "react-hooks", "react-refresh", "eslint-plugin-unicorn", "eslint-plugin-import"]
    },
    "prettier": {
      "enabled": true,
      "printWidth": 120,
      "tabWidth": 2,
      "useTabs": false,
      "semi": true,
      "singleQuote": true,
      "trailingComma": "es5",
      "bracketSpacing": true,
      "arrowParens": "always"
    }
  },
  "projectTemplates": {
    "recommended": ["ts-react", "typescript-node"],
    "legacy": ["js"]
  }
}
